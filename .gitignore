# Python / uv
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Data cache (datasets are fetched, never committed)
data/
.cache/

# Generated analysis artifacts
results/*.json
results/*.csv
papers/*/figures/*
papers/*/generated/*
!papers/*/figures/.gitkeep
!papers/*/generated/.gitkeep
# arXiv packages are assembled from the generated figures + .bbl (regenerate with `make arxiv`).
papers/*/arxiv-submission/

# Airflow runtime
airflow/logs/
airflow/*.cfg
airflow/*.db
airflow/.env

# LaTeX build aux
papers/*/*.aux
papers/*/*.log
papers/*/*.out
papers/*/*.bbl
papers/*/*.blg
papers/*/*.pdf

# OS / editors
.DS_Store

# Snakemake workflow state
.snakemake/
