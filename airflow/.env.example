# Copy to airflow/.env before `make airflow-up`. Podman-compose reads it automatically.

# Rootless Podman: set to 0 so the container's root maps to your host user and the
# bind-mounted logs/ and project/ stay writable & deletable. (The official image's
# default of 50000 produces root-owned files you can't remove under rootless podman.)
# On Docker (rootful), use your host UID instead:  AIRFLOW_UID=$(id -u)
AIRFLOW_UID=0

# Set to 1 to run the pipeline on the synthetic fixture (no network) instead of the
# real CHIME/FRB catalogue. Handy for a first smoke test of the stack.
JR_OFFLINE=0
